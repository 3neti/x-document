{
    "name": "3neti/x-document",
    "description": "Driver-neutral compiler for validated resolved-document contracts",
    "type": "library",
    "license": "proprietary",
    "authors": [
        {
            "name": "Lester Hurtado",
            "email": "lester@hurtado.ph"
        }
    ],
    "require": {
        "php": "^8.4",
        "opis/json-schema": "^2.6"
    },
    "require-dev": {
        "laravel/pint": "^1.29",
        "pestphp/pest": "^4.7",
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "LBHurtado\\XDocument\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LBHurtado\\XDocument\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.x-dev"
        }
    },
    "scripts": {
        "compatibility": "@php bin/x-document-compatibility",
        "test": "pest --compact",
        "analyse": "phpstan analyse --no-progress",
        "format": "pint --format agent"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
